{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A music video project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "audioUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "coverUrl": { "type": "string" },
        "style": { "type": "string" },
        "mood": { "type": "string" },
        "language": { "type": "string" },
        "prompt": { "type": "string" },
        "status": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "subtitles": { "type": "array" }
      },
      "required": ["audioUrl", "userId"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of music video projects"
    }
  }
}
